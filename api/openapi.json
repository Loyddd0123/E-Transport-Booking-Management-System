{
  "openapi": "3.0.0",
  "info": {
    "title": "E-Transport Booking & Management System API",
    "version": "1.0.0",
    "description": "API documentation for login, registration, schedules, bookings, payments, admin dashboard, and CRUD management features."
  },
  "servers": [
    {
      "url": "http://localhost/e_transport_system/api/index.php?r="
    }
  ],
  "tags": [
    { "name": "System" },
    { "name": "Authentication" },
    { "name": "Schedules" },
    { "name": "Bookings" },
    { "name": "Payments" },
    { "name": "Admin Dashboard" },
    { "name": "Admin Management" },
    { "name": "Admin CRUD" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "API Health Check",
        "responses": {
          "200": { "description": "API running" }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "passenger@etransport.local" },
                  "password": { "type": "string", "example": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid login" }
        }
      }
    },
    "/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register Account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "full_name": { "type": "string", "example": "Juan Dela Cruz" },
                  "email": { "type": "string", "example": "juan@email.com" },
                  "password": { "type": "string", "example": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Registered successfully" }
        }
      }
    },
    "/schedules": {
      "get": {
        "tags": ["Schedules"],
        "summary": "Get Available Schedules",
        "responses": {
          "200": { "description": "List of schedules" }
        }
      }
    },
    "/bookings": {
      "get": {
        "tags": ["Bookings"],
        "summary": "Get User Bookings",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "List of bookings" }
        }
      },
      "post": {
        "tags": ["Bookings"],
        "summary": "Create Booking",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": { "type": "integer", "example": 1 },
                  "schedule_id": { "type": "integer", "example": 1 },
                  "seats": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Booking successful" },
          "400": { "description": "No available seats / Not enough seats" }
        }
      }
    },
    "/payments": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get User Payments",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "List of payments" }
        }
      },
      "post": {
        "tags": ["Payments"],
        "summary": "Create Payment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "booking_id": { "type": "integer", "example": 1 },
                  "user_id": { "type": "integer", "example": 1 },
                  "method": { "type": "string", "example": "cash" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Payment successful" }
        }
      }
    },
    "/admin-reports": {
      "get": {
        "tags": ["Admin Dashboard"],
        "summary": "Admin - Dashboard Reports",
        "responses": {
          "200": { "description": "Totals: bookings, payments, revenue, users" }
        }
      }
    },
    "/admin-bookings": {
      "get": {
        "tags": ["Admin Management"],
        "summary": "Admin - Get All Bookings",
        "responses": {
          "200": { "description": "List of all bookings" }
        }
      }
    },
    "/admin-payments": {
      "get": {
        "tags": ["Admin Management"],
        "summary": "Admin - Get All Payments",
        "responses": {
          "200": { "description": "List of all payments" }
        }
      }
    },
    "/admin-users": {
      "get": {
        "tags": ["Admin Management"],
        "summary": "Admin - Get All Users",
        "responses": {
          "200": { "description": "List of users" }
        }
      }
    },
    "/admin-routes": {
      "get": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Get All Routes",
        "responses": {
          "200": { "description": "List of routes" }
        }
      },
      "post": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Add Route",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "origin": { "type": "string", "example": "City Terminal" },
                  "destination": { "type": "string", "example": "Airport" },
                  "fare": { "type": "number", "example": 180 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Route added successfully" }
        }
      },
      "put": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Update Route",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer", "example": 1 },
                  "origin": { "type": "string", "example": "City Terminal" },
                  "destination": { "type": "string", "example": "Airport" },
                  "fare": { "type": "number", "example": 180 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Route updated" }
        }
      },
      "delete": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Delete Route",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Route deleted" }
        }
      }
    },
    "/admin-vehicles": {
      "get": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Get All Vehicles",
        "responses": {
          "200": { "description": "List of vehicles" }
        }
      },
      "post": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Add Vehicle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "plate_number": { "type": "string", "example": "ABC-1234" },
                  "vehicle_type": { "type": "string", "example": "Van" },
                  "seat_capacity": { "type": "integer", "example": 14 },
                  "status": { "type": "string", "example": "Available" },
                  "maintenance_status": { "type": "string", "example": "Good" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vehicle added successfully" }
        }
      },
      "put": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Update Vehicle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer", "example": 1 },
                  "plate_number": { "type": "string", "example": "ABC-1234" },
                  "vehicle_type": { "type": "string", "example": "Van" },
                  "seat_capacity": { "type": "integer", "example": 14 },
                  "status": { "type": "string", "example": "Available" },
                  "maintenance_status": { "type": "string", "example": "Good" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vehicle updated" }
        }
      },
      "delete": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Delete Vehicle",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Vehicle deleted" }
        }
      }
    },
    "/admin-schedules": {
      "post": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Add Schedule",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "route_id": { "type": "integer", "example": 1 },
                  "vehicle_id": { "type": "integer", "example": 1 },
                  "departure_time": { "type": "string", "example": "2026-06-02 01:00:00" },
                  "arrival_time": { "type": "string", "example": "2026-06-02 01:00:00" },
                  "status": { "type": "string", "example": "Active" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Schedule added successfully" }
        }
      },
      "put": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Update Schedule",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer", "example": 1 },
                  "route_id": { "type": "integer", "example": 1 },
                  "vehicle_id": { "type": "integer", "example": 1 },
                  "departure_time": { "type": "string", "example": "2026-06-02 01:00:00" },
                  "arrival_time": { "type": "string", "example": "2026-06-02 01:00:00" },
                  "status": { "type": "string", "example": "Active" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Schedule updated" }
        }
      },
      "delete": {
        "tags": ["Admin CRUD"],
        "summary": "Admin - Delete Schedule",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Schedule deleted" }
        }
      }
    }
  }
}